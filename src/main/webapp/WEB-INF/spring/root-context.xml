<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:aop="http://www.springframework.org/schema/aop"
	xmlns:context="http://www.springframework.org/schema/context"
	xmlns:tx="http://www.springframework.org/schema/tx"
	xsi:schemaLocation="http://www.springframework.org/schema/beans https://www.springframework.org/schema/beans/spring-beans.xsd
		http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context-4.3.xsd
		http://www.springframework.org/schema/aop http://www.springframework.org/schema/aop/spring-aop-4.3.xsd
		http://www.springframework.org/schema/tx http://www.springframework.org/schema/tx/spring-tx-4.3.xsd">


	<!-- upload.properties 로딩 — FileManager @Value 주입을 위해 root-context 에도 필요 -->
	<context:property-placeholder
		location="classpath:config/upload.properties,classpath:config/upload.local.properties"
		ignore-resource-not-found="true" />

	<!--  MyBatis 설정 -->
	<!-- @Mapper interface -->
	<bean class="org.mybatis.spring.mapper.MapperScannerConfigurer">
		<!--일괄 빈 등록-->
		<property name="basePackage" value="com.pcwk.ehr.mapper"/>
		
		<!--연결할 SqlSessionFactory 의 빈 이름을 지정 : 선택  -->
<!-- 		<property name="sqlSessionFactoryBeanName" value="sqlSessionFactory"/> -->
		
		
		
	</bean>
	
	
	
	<!-- SQL SessionTemplate -->
	<bean id="SqlSessionTemplate" class="org.mybatis.spring.SqlSessionTemplate">
		<constructor-arg index="0" ref = "SqlSessionFactoryBean"></constructor-arg>
	</bean>	
	
	<!--  SQL SessionFactoryBean  -->
		<bean id = "SqlSessionFactoryBean" class="org.mybatis.spring.SqlSessionFactoryBean">
			<property name = "dataSource" ref = "dataSource"></property>
		
			<!--mybatis-config.xml  -->
			<property name="configLocation" value="classpath:mybatis-config.xml"></property>
			
			<!-- mapper : sql -->
			<property name="mapperLocations" value="classpath:mapper/**/*.xml"></property>

			
		</bean>


	<!--   -->


<!-- Root Context: defines shared resources visible to all other web components -->

		<!-- Service·@Component 등 — @Transactional 은 이 컨텍스트에서만 적용 -->
		<context:component-scan base-package="com.pcwk.ehr">
			<context:exclude-filter type="annotation"
				expression="org.springframework.stereotype.Controller" />
		</context:component-scan>

		<aop:config>
			<aop:pointcut
				expression="execution(* com.pcwk.ehr..service.*Impl.up*(..))"
				id="txPointcut" />
			<!-- advice + pointcut -->
			<aop:advisor advice-ref="txAdvice"
				pointcut-ref="txPointcut" />

		</aop:config>



		<!-- 트랜잭션 Advice: 트랜잭션 규칙, 정책 name = "up*" -> 적용 대상 : 메서드 up 으로 시작 propagation 
			= "REQUIRES_NEW" -> 항상 새로운 트랜잭션 생성 isolation="SERIALIZABLE" -> 가장 경리 수준 예시 
			: =>upgradeLevels() update() uploadFile() ================================================================== 
			name = "*" -> 모든 메서드 propagation="REQUIRED" -> 기본값 read-only="true" -> 읽기 
			전용 트랜잭션 예시 : => doSelectOne() doSave() doRetrieve() 등.. -->

		<tx:advice id="txAdvice"
			transaction-manager="transactionManager">
			<tx:attributes>
				<tx:method name="up*" propagation="REQUIRES_NEW"
					isolation="SERIALIZABLE" />
				<tx:method name="*" propagation="REQUIRED"
					read-only="true" />
			</tx:attributes>
		</tx:advice>


		<!-- 트랜잭션 어노테이션 활성화 : @Transactional -->
		<tx:annotation-driven proxy-target-class="true"
			transaction-manager="transactionManager" />


		<bean id="transactionManager"
			class="org.springframework.jdbc.datasource.DataSourceTransactionManager">
			<constructor-arg name="dataSource" ref="dataSource"></constructor-arg>
		</bean>

